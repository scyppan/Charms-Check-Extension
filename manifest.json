{
  "name": "Charms Check Extension 25",
  "version": "25.5.26.001",
  "manifest_version": 3,
  "description": "A google meet based extension for Charms Check",
  "author": "Scyppan",
  "permissions": [
    "tabs"
  ],
  "content_scripts": [
    {
      "css": [
        "style.css",
        "battle.css",
        "backgroundrand.css"
      ],
      "matches": [
        "https://meet.google.com/*"
      ],
      "exclude_matches": [
        "https://meet.google.com/landing*",
        "https://meet.google.com/*/unsupported"
      ],
      "js": [
        "utils.js",
        "panel.js",
        "crosssite.js",
        "main.js",
        "mutation.js",
        "battlemanager.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/house16.png",
      "48": "icons/house48.png",
      "128": "icons/house128.png"
    },
    "default_popup": "battlemanager.html",
    "default_title": "Charms Check Chrome Extension for Google Meet"
  }
}